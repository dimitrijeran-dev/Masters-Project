{
  "summary_path": "Data/New Data/deterministic_study_summary.json",
  "metadata_compatibility_keys": ["run_name", "a", "E", "nu", "plane_stress"],
  "steps": [
    {
      "name": "deterministic_mesh",
      "module": "FEM.mesh",
      "function": "main",
      "artifacts": [
        "Data/New Data/meshrun_0.055mm/plate_edge_crack_q4.msh"
      ]
    },
    {
      "name": "deterministic_solve",
      "module": "FEM.fem_solver",
      "function": "main",
      "metadata_path": "Data/New Data/meshrun_0.055mm/metadata.json",
      "artifacts": [
        "Data/New Data/meshrun_0.055mm/solution_q4.vtk",
        "Data/New Data/meshrun_0.055mm/fields.npz",
        "Data/New Data/meshrun_0.055mm/metadata.json"
      ],
      "key_metrics": [
        {"name": "KI", "source": "metadata", "key": "KI"},
        {"name": "J", "source": "metadata", "key": "J"}
      ]
    },
    {
      "name": "deterministic_validation",
      "module": "FEM.validate_fields",
      "function": "main",
      "metadata_path": "Data/New Data/meshrun_0.055mm/validation_summary.json",
      "artifacts": [
        "Data/New Data/meshrun_0.055mm/validation_summary.json",
        "Data/New Data/meshrun_0.055mm/validation_line.csv",
        "Data/New Data/meshrun_0.055mm/KI_vs_rout.png"
      ],
      "key_metrics": [
        {"name": "KI_ref", "source": "metadata", "key": "KI_ref"},
        {"name": "JK_relative_residual", "source": "metadata", "key": "JK_relative_residual"}
      ]
    }
  ]
}
