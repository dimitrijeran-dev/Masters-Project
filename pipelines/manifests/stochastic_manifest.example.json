{
  "summary_path": "Data/New Data/stochastic_study_summary.json",
  "metadata_compatibility_keys": ["run_name", "a", "nu", "plane_stress"],
  "steps": [
    {
      "name": "stochastic_mesh",
      "module": "Stochastic_FEM.stochastic_mesh",
      "function": "main",
      "metadata_path": "Data/New Data/Deterministic_config_plate_edge_crack/geometry_metadata.json",
      "artifacts": [
        "Data/New Data/Deterministic_config_plate_edge_crack/mesh_q4.msh",
        "Data/New Data/Deterministic_config_plate_edge_crack/geometry_metadata.json"
      ]
    },
    {
      "name": "stochastic_solve",
      "module": "Stochastic_FEM.stochastic_fem_solver",
      "function": "main",
      "metadata_glob": "Data/New Data/Deterministic_config_plate_edge_crack/metadata_mc*.json",
      "artifacts": [
        "Data/New Data/Deterministic_config_plate_edge_crack/fields_mc0000.npz"
      ],
      "key_metrics": [
        {"name": "solver_run_name", "source": "metadata", "key": "run_name"}
      ]
    },
    {
      "name": "stochastic_validation",
      "module": "Stochastic_FEM.stochastic_validate_fields",
      "function": "main",
      "metadata_glob": "Data/New Data/Deterministic_config_plate_edge_crack/validation_summary_mc*.json",
      "artifacts": [
        "Data/New Data/Deterministic_config_plate_edge_crack/validation_summary_all_realizations.json"
      ],
      "key_metrics": [
        {"name": "KI_ref_by_realization", "source": "metadata", "key": "KI_ref"}
      ]
    }
  ]
}
